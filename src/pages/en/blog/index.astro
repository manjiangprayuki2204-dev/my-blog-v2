---
/**
 * English Blog List Page
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import TagFilter from "../../../components/TagFilter.astro";
import { getTranslations } from "../../../i18n/index";
import type { Lang } from "../../../i18n/index";
import { getArticlePreviews, sortByDate, filterByTag } from "../../../services/articles";
import { DEFAULT_TAGS_EN } from "../../../domain/article";

const lang: Lang = "en";
const t = getTranslations(lang);

const activeTag = Astro.url.searchParams.get("tag") || "All";

const allArticleEntries = await Astro.glob("content/articles/*.md");
const articles = allArticleEntries.map((entry: any) => entry.frontmatter);
const publishedPreviews = sortByDate(getArticlePreviews(articles, lang));
const filteredArticles = filterByTag(publishedPreviews, activeTag);
---

<BaseLayout title={t.blog.title}>
  <div class="blog-list-header">
    <h1 class="blog-list-title">{t.blog.title}</h1>
    <div class="blog-filter-bar">
      <TagFilter
        tags={[...DEFAULT_TAGS_EN]}
        activeTag={activeTag}
        lang={lang}
      />
    </div>
  </div>

  <div class="container">
    {
      filteredArticles.length > 0 ? (
        <div class="blog-grid">
          {filteredArticles.map((article) => (
            <ArticleCard article={article} lang={lang} />
          ))}
        </div>
      ) : (
        <p class="text-center" style="color:var(--color-text-secondary);padding:48px;">
          {t.blog.noResults}
        </p>
      )
    }
  </div>
</BaseLayout>
