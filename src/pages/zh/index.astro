---
/**
 * 中文首页
 * Hero + 最新文章 + 作品精选 + 页脚
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getTranslations } from "../../i18n/index";
import type { Lang } from "../../i18n/index";
import { getArticlePreviews, sortByDate, getLatest } from "../../services/articles";
import { getWorkPreviews, getFeaturedWorks } from "../../services/works";
import { DEFAULT_PROFILE } from "../../domain/profile";

const lang: Lang = "zh";
const t = getTranslations(lang);

// ===== 加载个人资料 =====
let profile = DEFAULT_PROFILE;
try {
  const profileEntries = await Astro.glob("content/profile/*.md");
  if (profileEntries.length > 0) {
    profile = { ...DEFAULT_PROFILE, ...(profileEntries[0] as any).frontmatter };
  }
} catch { /* 使用默认值 */ }

// ===== 加载内容数据 =====
// 使用 Astro.glob 加载所有 Markdown 内容

// 加载文章
const allArticleEntries = await Astro.glob("content/articles/*.md");
const articles = allArticleEntries.map((entry: any) => entry.frontmatter);
const publishedPreviews = sortByDate(getArticlePreviews(articles, lang));
const latestPosts = getLatest(publishedPreviews, 3);

// 加载作品
const allWorkEntries = await Astro.glob("content/works/*.md");
const works = allWorkEntries.map((entry: any) => entry.frontmatter);
const publishedWorks = getWorkPreviews(works, lang);
const featuredWorks = getFeaturedWorks(publishedWorks, 2);
---

<BaseLayout>
  <!-- Hero 区域 -->
  <Hero profile={profile} />

  <!-- 最新文章 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t.home.latestPosts}</h2>
        <div class="section-divider"></div>
      </div>

      {
        latestPosts.length > 0 ? (
          <div class="article-grid">
            {latestPosts.map((article) => (
              <ArticleCard article={article} lang={lang} />
            ))}
          </div>
        ) : (
          <p class="text-center" style="color:var(--color-text-secondary);padding:32px;">
            还没有文章，在后台创建第一篇吧 🌱
          </p>
        )
      }

      {publishedPreviews.length > 3 && (
        <div class="text-center mt-4">
          <a href={`/${lang}/blog/`} class="btn btn-outline">
            {t.home.viewAll} →
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- 作品精选 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{t.home.featuredWorks}</h2>
        <div class="section-divider"></div>
      </div>

      {
        featuredWorks.length > 0 ? (
          <div class="works-grid">
            {featuredWorks.map((work) => (
              <WorkCard work={work} lang={lang} />
            ))}
          </div>
        ) : (
          <p class="text-center" style="color:var(--color-text-secondary);padding:32px;">
            还没有作品，在后台添加第一个吧 ✨
          </p>
        )
      }

      {publishedWorks.length > 2 && (
        <div class="text-center mt-4">
          <a href={`/${lang}/works/`} class="btn btn-outline">
            {t.home.viewAll} →
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
